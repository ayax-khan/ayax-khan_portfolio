# ⚠️  SECURITY WARNING
# Never commit real credentials. Use strong random passwords.
# On Vercel, set these via Environment Variables in the dashboard.
#
# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portfolio?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/portfolio"

# GitHub (server-side only — used to fetch repos and commits)
GITHUB_TOKEN="ghp_xxx"
GITHUB_USERNAME="your-github-username"
# If your repos are under a GitHub org instead of a personal account, set this:
GITHUB_ORG="your-org-name"

# Site
SITE_URL="http://localhost:3000"
SITE_DESCRIPTION="Secure, performance-focused developer portfolio with projects, writing, and contact."

# Profile (optional — overrides are stored in DB via admin panel)
PROFILE_NAME="Your Name"
PROFILE_ROLE="Software Engineer"
PROFILE_HEADLINE="I build secure, high-performance web systems with TypeScript, Next.js, and Postgres."
PROFILE_LOCATION="Your City"
PROFILE_EMAIL="you@example.com"

# Socials (optional — overrides are stored in DB via admin panel)
SOCIAL_GITHUB="https://github.com/yourusername"
SOCIAL_LINKEDIN="https://www.linkedin.com/in/yourprofile/"
SOCIAL_X="https://x.com/yourhandle"

# Admin (protects /admin routes — use a strong random password)
ADMIN_USER="admin"
ADMIN_PASSWORD="generate-a-strong-random-password-here"

# Upstash Redis for rate limiting (optional — skips if not set)
# UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-token"
